<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Celia Bloom | Collections</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #fdfaf9; }
        .collection-card { border-radius: 25px; border: 1px solid #e5d5d0; transition: all 0.3s; }
        .collection-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect } = React;

        function CeliaBloom() {
            const [collections, setCollections] = useState(() => {
                const saved = localStorage.getItem("celia_collections");
                return saved ? JSON.parse(saved) : [
                    { id: 1, name: "أجهزة تصفيف الشعر", imageUrl: "https://images.unsplash.com/photo-1522336572018-02880f3f446a?w=400", link: "#" },
                    { id: 2, name: "مجموعات الماكياج", imageUrl: "https://images.unsplash.com/photo-1522338221027-2f27b441c5d0?w=400", link: "#" },
                    { id: 3, name: "حقائب راقية", imageUrl: "https://images.unsplash.com/photo-1584917865442-de89df76afd3?w=400", link: "#" },
                    { id: 4, name: "ساعات أنيقة", imageUrl: "https://images.unsplash.com/photo-1524592094714-0f0654e20314?w=400", link: "#" }
                ];
            });

            return (
                <div className="min-h-screen">
                    {/* Header بحال LunaChic */}
                    <div className="bg-[#744d3d] text-white text-center py-2 text-sm font-medium">
                        توصيل لجميع المدن المغربية 🇲🇦
                    </div>
                    
                    <header className="bg-white py-6 px-6 flex justify-between items-center shadow-sm">
                        <div className="text-2xl font-bold tracking-tighter text-[#4a332a]">CELIA BLOOM</div>
                        <div className="flex gap-4">
                            <span>🔍</span>
                            <span>👜</span>
                        </div>
                    </header>

                    <main className="max-w-6xl mx-auto p-6 pt-10">
                        <h2 className="text-4xl font-bold text-[#4a332a] mb-10 text-right">Collections</h2>
                        
                        {/* Grid ديال المجموعات */}
                        <div className="grid grid-cols-2 md:grid-cols-2 gap-6">
                            {collections.map(col => (
                                <div key={col.id} className="collection-card bg-white overflow-hidden p-2">
                                    <div className="aspect-[4/5] bg-gray-100 rounded-[20px] overflow-hidden">
                                        <img src={col.imageUrl} alt={col.name} className="w-full h-full object-cover" />
                                    </div>
                                    <div className="p-4 flex justify-between items-center">
                                        <h3 className="text-lg font-bold text-[#4a332a]">{col.name}</h3>
                                        <span className="text-xl">→</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </main>

                    {/* Footer بسيط */}
                    <footer className="mt-20 py-10 border-t bg-white text-center">
                        <p className="text-[#744d3d] font-bold">Celia Bloom</p>
                        <p className="text-xs text-gray-400 mt-2">© 2026 جميع الحقوق محفوظة</p>
                    </footer>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<CeliaBloom />);
    </script>
</body>
</html>
