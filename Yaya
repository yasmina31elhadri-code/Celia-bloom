<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Celia Bloom | Premium Boutique</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Cairo', sans-serif; background-color: #fff; color: #4a332a; }
        .nav-link { font-size: 14px; font-weight: 600; color: #4a332a; text-transform: uppercase; }
        .hero-gradient { background: linear-gradient(rgba(0,0,0,0.1), rgba(0,0,0,0.4)); }
        .collection-card img { transition: transform 0.5s ease; }
        .collection-card:hover img { transform: scale(1.05); }
    </style>
</head>
<body>
    <div id="root"></div>

    <script type="text/babel">
        const { useState } = React;

        function CeliaBloom() {
            const collections = [
                { id: 1, name: "أجهزة تصفيف الشعر", imageUrl: "https://images.unsplash.com/photo-1522336572018-02880f3f446a?auto=format&fit=crop&w=600&q=80" },
                { id: 2, name: "Coffret Makeup - مجموعات", imageUrl: "https://images.unsplash.com/photo-1522338221027-2f27b441c5d0?auto=format&fit=crop&w=600&q=80" },
                { id: 3, name: "حقائب راقية", imageUrl: "https://images.unsplash.com/photo-1584917865442-de89df76afd3?auto=format&fit=crop&w=600&q=80" },
                { id: 4, name: "ساعات مونتر", imageUrl: "https://images.unsplash.com/photo-1524592094714-0f0654e20314?auto=format&fit=crop&w=600&q=80" }
            ];

            return (
                <div className="min-h-screen">
                    {/* شريط الإعلان العلوي */}
                    <div className="bg-[#5c3d31] text-white text-center py-2 text-xs font-bold tracking-widest">
                        LIVRAISON PARTOUT AU MAROC 🇲🇦
                    </div>

                    {/* Navbar */}
                    <nav className="flex items-center justify-between px-6 py-5 border-b sticky top-0 bg-white z-50">
                        <div className="flex gap-4 items-center">
                            <span className="text-2xl italic">☰</span>
                        </div>
                        <div className="text-3xl font-bold tracking-widest text-[#4a332a]">CELIA BLOOM</div>
                        <div className="flex gap-4 items-center">
                            <span>🔍</span>
                            <span className="relative">👜</span>
                        </div>
                    </nav>

                    {/* Banner الرئيسي (Hero) */}
                    <section className="relative h-[60vh] bg-gray-200 overflow-hidden">
                        <img 
                            src="https://images.unsplash.com/photo-1596462502278-27bfdc4033c8?auto=format&fit=crop&w=1200&q=80" 
                            className="w-full h-full object-cover"
                            alt="Main Banner"
                        />
                        <div className="absolute inset-0 hero-gradient flex flex-col justify-center items-center text-white text-center p-6">
                            <h2 className="text-4xl font-bold mb-4 tracking-tighter uppercase">New Collection 2026</h2>
                            <p className="mb-6 text-sm tracking-wide">اكتشفي عالم الجمال والأناقة مع سِيليا بْلُوم</p>
                            <button className="bg-white text-black px-8 py-3 font-bold text-xs uppercase tracking-widest hover:bg-black hover:text-white transition">Explore Now</button>
                        </div>
                    </section>

                    {/* قسم المجموعات (Collections) بحال LunaChic */}
                    <main className="max-w-6xl mx-auto px-4 py-16">
                        <h2 className="text-4xl font-bold text-center mb-16 tracking-tight">Collections</h2>
                        
                        <div className="grid grid-cols-2 md:grid-cols-2 gap-4 md:gap-8">
                            {collections.map(col => (
                                <div key={col.id} className="collection-card group cursor-pointer">
                                    <div className="aspect-[3/4] overflow-hidden rounded-2xl bg-[#f9f4f1] mb-4">
                                        <img 
                                            src={col.imageUrl} 
                                            alt={col.name} 
                                            className="w-full h-full object-cover"
                                        />
                                    </div>
                                    <div className="flex justify-between items-center px-2">
                                        <h3 className="text-xl font-bold text-[#4a332a]">{col.name}</h3>
                                        <span className="text-2xl group-hover:translate-x-[-5px] transition-transform">→</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </main>

                    {/* Footer */}
                    <footer className="bg-[#f9f4f1] mt-20 pt-16 pb-10 px-6 border-t border-[#e5d5d0]">
                        <div className="text-center mb-10">
                            <h2 className="text-2xl font-bold mb-4">Celia Bloom</h2>
                            <p className="text-sm text-gray-500 max-w-xs mx-auto">أفضل منتجات التجميل والأناقة بجودة عالية وتوصيل سريع.</p>
                        </div>
                        <div className="flex justify-center gap-6 mb-8 text-xl">
                            <span>Instagram</span>
                            <span>WhatsApp</span>
                        </div>
                        <div className="text-center text-[10px] text-gray-400 tracking-[3px] uppercase">
                            © 2026 CELIA BLOOM OFFICIAL
                        </div>
                    </footer>
                </div>
            );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<CeliaBloom />);
    </script>
</body>
</html>
